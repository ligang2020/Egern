
#!desc=移除速度检测、红绿灯、头盔检测及零售单过滤。采用 Map Local 模拟成功响应，防止 App 报错。
#!system=ios

[Rule]
# 屏蔽不影响主业务的域名
DOMAIN,aiot.ele.me,REJECT

[Map Local]
# 1. 屏蔽高德地图相关检测
^https?:\/\/.*amap\.com\/ws\/mps\/rtt data-type=text status-code=200 body="{}"

# 2. 屏蔽饿了么零售/超市单相关
^https?:\/\/.*ele\.me\/.*(retail|supermarket) data-type=text status-code=200 body="{}"

# 3. 屏蔽头盔、速度检测等相关接口
^https?:\/\/.*ele\.me\/.*(helmet|detect|speed) data-type=text status-code=200 body="{}"

[MITM]
hostname = %APPEND% *.amap.com, *.ele.me

