#!name=国家电网 Token 抓取
#!desc=自动抓取“网上国网”App登录凭证，用于自动化脚本。
#!category=脚本
#!author=Gemini

[MITM]
hostname = %APPEND% *.95598.cn, *.sgcc.com.cn

[Script]
# 匹配首页刷新或用户信息查询接口
http-request ^https?://.*\.95598\.cn/(.*)/user/(info|detail) script-path=https://raw.githubusercontent.com/YourRepo/scripts/main/sgcc.js, tag=国网Token抓取
